# VPS configuration template
# Copy to $VPS_CONFIG_DIR/.env and populate with your values.
# Never commit the populated .env file to Git.

# ---- Repository identity ----
VPS_REPO_ROOT=/home/scraper/apps/ivy-control-vps
VPS_STATE_DIR=/home/scraper/.ivy-control-vps

# ---- Approved SHA (set by deployment gate) ----
VPS_EXPECTED_SHA=0000000000000000000000000000000000000000

# ---- Remote verification ----
VPS_EXPECTED_REMOTE=https://github.com/anomalyco/ivy-control-vps.git

# ---- State sub-directories (all under VPS_STATE_DIR by default) ----
# VPS_GENERATED_DIR=/home/scraper/.ivy-control-vps/generated
# VPS_CONFIG_DIR=/home/scraper/.ivy-control-vps/config
# VPS_DATA_DIR=/home/scraper/.ivy-control-vps/data
# VPS_LOG_DIR=/home/scraper/.ivy-control-vps/logs
# VPS_BACKUP_DIR=/home/scraper/.ivy-control-vps/backups

# ---- SHA registry ----
# VPS_SHA_REGISTRY=/home/scraper/.ivy-control-vps/sha-registry.json
